# DeepSeek API key (primary LLM for copilot)
# Get yours at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-key-here

# DeepSeek model: "deepseek-chat" = V3, "deepseek-reasoner" = R1
DEEPSEEK_MODEL=deepseek-chat

# Optional: Groq API key as fallback if DeepSeek is down
# Get yours at https://console.groq.com/keys
# GROQ_API_KEY=
