---
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/global.css";

const projects = [
  {
    slug: "multi-agent-openclaw",
    title: "Multi-Agent OpenClaw Orchestration",
    summary: "Designed a role-based multi-agent assistant system with explicit orchestration, specialist routing, durable memory, and handoff workflows that made long-running AI work more reliable across sessions.",
    tags: ["Agent Architecture", "Orchestration", "Memory Design", "OpenClaw"],
    status: "live",
    category: "Agentic Systems",
  },
  {
    slug: "hermes-obsidian-gbrain",
    title: "Jarvis: Hermes AI Operating System",
    summary: "A persistent, always-on AI operating system built on Hermes Agent — with layered memory, a 125-skill procedural library, a 590-file Obsidian knowledge vault backed by GitHub, and cron-driven autonomous workflows accessible via Telegram.",
    tags: ["Hermes Agent", "Python", "Obsidian", "Telegram", "Cron Automation", "OpenAI"],
    status: "live",
    category: "Agentic Platform",
  },
  {
    slug: "employee-communication-simulator",
    title: "Employee Communication Simulator",
    summary: "Built a simulation platform for testing how leadership messages land across a 450-person org — with weighted personas, Monte Carlo scenario analysis, multi-provider LLM integration, and executive-ready reporting in PDF and PowerPoint.",
    tags: ["Python", "React 19", "Multi-LLM", "Monte Carlo", "Executive Reporting", "Decision Support"],
    status: "live",
    category: "Decision-Support Systems",
  },
  {
    slug: "browser-workflow-qa-agent",
    title: "Browser Workflow QA Agent",
    summary: "An AI agent that performs structured quality assurance on live websites — navigating pages, auditing browser console state, capturing desktop and mobile screenshots, and producing evidence-backed PASS/WARN/FAIL reports triggered by a single natural-language Telegram message.",
    tags: ["Python", "Browser Automation", "Agentic Workflows", "Telegram", "QA Engineering", "TDD"],
    status: "live",
    category: "Agentic QA & Automation",
  },
  {
    slug: "agent-trust-control-plane",
    title: "Agent Trust Control Plane",
    summary: "Built a local governance layer for AI agents that classifies proposed actions as allow, approval_required, clarification_required, or blocked — with YAML policies, deterministic risk classification, human approval gates, and JSONL audit trails.",
    tags: ["Python", "Policy Engine", "Risk Classification", "Audit Logging", "Agent Safety"],
    status: "live",
    category: "Agent Governance",
  },
  {
    slug: "opscore-dashboard",
    title: "OpsCore Dashboard",
    summary: "A real-time operational dashboard for monitoring containerized AI services on a VPS — with a Python metrics agent collecting system health data and a Next.js frontend on Vercel for remote visibility into CPU, memory, disk, and container status.",
    tags: ["Next.js", "TypeScript", "Python", "Docker", "Traefik", "Vercel"],
    status: "live",
    category: "Infrastructure & Observability",
  },
  {
    slug: "memory-reliability-for-agents",
    title: "Durable Memory for AI Agents",
    summary: "A reliability engineering case study on designing a structured memory and reminder durability layer for a multi-agent AI operating system, using explicit source-of-truth artifacts, retrieval rules, and handoff workflows to make long-running agent work recoverable and trustworthy.",
    tags: ["Reliability", "Memory Design", "Agent Systems", "Durable State", "Operational Hygiene"],
    status: "live",
    category: "AI Reliability",
  },
];
---

<BaseLayout title="Projects — Pradeep" description="Selected projects that show how I think about AI, systems, and product.">

  <section class="py-24">
    <div class="max-w-6xl mx-auto px-6">
      <p class="font-mono text-accent-blue text-sm mb-3">~/projects</p>
      <h1 class="text-4xl font-bold text-text-primary mb-4">Selected Work</h1>
      <p class="text-text-secondary text-lg max-w-2xl mb-16">
        Projects that represent how I think about AI systems, product design, and engineering
        leadership. Each one taught me something worth showing.
      </p>

      <div class="space-y-6">
        {projects.map((project, index) => (
          <a
            href={project.status === "live" ? `/projects/${project.slug}` : "#"}
            class:list={[
              "group block p-6 md:p-8 rounded-xl border transition-all duration-300",
              project.status === "live"
                ? "bg-surface-800/50 border-border hover:border-accent-blue/40 hover:bg-surface-800"
                : "bg-surface-800/20 border-border/50 opacity-50 cursor-default",
            ]}
          >
            <div class="flex flex-col md:flex-row md:items-start justify-between gap-4">
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-3">
                  <span class="font-mono text-text-muted text-sm">0{index + 1}</span>
                  {project.status === "live" && (
                    <span class="inline-flex items-center gap-1.5 text-xs font-mono text-success">
                      <span class="w-1.5 h-1.5 rounded-full bg-success" />
                      live
                    </span>
                  )}
                  {project.status === "upcoming" && (
                    <span class="text-xs font-mono text-text-muted">coming soon</span>
                  )}
                </div>
                <h2 class="text-xl font-semibold text-text-primary mb-2 group-hover:text-accent-blue transition-colors">
                  {project.title}
                </h2>
                <p class="text-text-secondary text-sm leading-relaxed mb-4 max-w-2xl">
                  {project.summary}
                </p>
                <div class="flex flex-wrap gap-2 mb-5">
                  {project.tags.map((tag) => (
                    <span class="px-2.5 py-1 text-xs font-mono rounded-md bg-surface-900 text-text-muted border border-border">
                      {tag}
                    </span>
                  ))}
                </div>
                {project.status === "live" && (
                  <span class="inline-flex items-center gap-1.5 text-sm font-medium text-accent-blue group-hover:gap-3 transition-all duration-200">
                    View case study
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                    </svg>
                  </span>
                )}
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
