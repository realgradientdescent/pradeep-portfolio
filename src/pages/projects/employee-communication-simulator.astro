                <marker id="ecs-arr" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto">
                  <polygon points="0 0, 8 3, 0 6" fill="#475569"/>
                </marker>
              </defs>
              <rect width="700" height="390" fill="#1e293b"/>
              <text x="22" y="26" font-family="JetBrains Mono, monospace" font-size="11" fill="#3b82f6">System Flow</text>
              <!-- Left panel: React Dashboard -->
              <rect x="18" y="38" width="196" height="220" rx="8" fill="#0f172a" stroke="#334155" stroke-width="1"/>
              <rect x="18" y="38" width="196" height="32" rx="8" fill="#172554" stroke="#3b82f6" stroke-width="1.5"/>
              <rect x="18" y="54" width="196" height="16" fill="#172554"/>
              <text x="116" y="59" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10.5" fill="#3b82f6">React Dashboard</text>
              <text x="36" y="92" font-family="Inter, system-ui, sans-serif" font-size="9.5" fill="#64748b">› Run setup &amp; filters</text>
              <text x="36" y="110" font-family="Inter, system-ui, sans-serif" font-size="9.5" fill="#64748b">› Persona explorer</text>
              <text x="36" y="128" font-family="Inter, system-ui, sans-serif" font-size="9.5" fill="#64748b">› Monte Carlo viewer</text>
              <text x="36" y="146" font-family="Inter, system-ui, sans-serif" font-size="9.5" fill="#64748b">› Saved run browser</text>
              <text x="36" y="164" font-family="Inter, system-ui, sans-serif" font-size="9.5" fill="#64748b">› Job status polling</text>
              <text x="36" y="182" font-family="Inter, system-ui, sans-serif" font-size="9.5" fill="#64748b">› Refresh recovery</text>
              <text x="36" y="200" font-family="Inter, system-ui, sans-serif" font-size="9.5" fill="#64748b">› PDF / PPTX reports</text>
              <text x="36" y="218" font-family="Inter, system-ui, sans-serif" font-size="9.5" fill="#64748b">› Run reload</text>
              <!-- Arrow: Dashboard → API Server -->
              <line x1="214" y1="64" x2="236" y2="64" stroke="#475569" stroke-width="1.5" marker-end="url(#ecs-arr)"/>
              <!-- API Server -->
              <rect x="239" y="44" width="440" height="40" rx="6" fill="#0f172a" stroke="#334155" stroke-width="1"/>
              <text x="459" y="62" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10.5" fill="#3b82f6">Python API Server</text>
              <text x="459" y="77" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="9" fill="#64748b">HTTP endpoints · threads · async dispatch · static serving</text>
              <!-- Arrow: API → Job Layer -->
              <line x1="459" y1="84" x2="459" y2="100" stroke="#475569" stroke-width="1.5" marker-end="url(#ecs-arr)"/>
              <!-- Job Layer -->
              <rect x="239" y="103" width="440" height="44" rx="6" fill="#0f172a" stroke="#334155" stroke-width="1"/>
              <text x="459" y="120" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10.5" fill="#3b82f6">Background Job Layer</text>
              <rect x="255" y="129" width="56" height="14" rx="3" fill="#1e293b" stroke="#334155" stroke-width="1"/>
              <text x="283" y="140" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="8" fill="#94a3b8">Queued</text>
              <text x="316" y="140" font-family="Inter, system-ui, sans-serif" font-size="9" fill="#475569">→</text>
              <rect x="323" y="129" width="58" height="14" rx="3" fill="#1e293b" stroke="#334155" stroke-width="1"/>
              <text x="352" y="140" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="8" fill="#94a3b8">Running</text>
              <text x="386" y="140" font-family="Inter, system-ui, sans-serif" font-size="9" fill="#475569">→</text>
              <rect x="393" y="129" width="88" height="14" rx="3" fill="#1e293b" stroke="#334155" stroke-width="1"/>
              <text x="437" y="140" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="8" fill="#94a3b8">Checkpointed</text>
              <text x="486" y="140" font-family="Inter, system-ui, sans-serif" font-size="9" fill="#475569">→</text>
              <rect x="493" y="129" width="172" height="14" rx="3" fill="#1e293b" stroke="#334155" stroke-width="1"/>
              <text x="579" y="140" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="8" fill="#94a3b8">Interrupted / recovered</text>
              <!-- Arrow: Job → Sim Engine -->
              <line x1="459" y1="147" x2="459" y2="164" stroke="#475569" stroke-width="1.5" marker-end="url(#ecs-arr)"/>
              <!-- Simulation Engine -->
              <rect x="239" y="167" width="440" height="54" rx="6" fill="#0f172a" stroke="#334155" stroke-width="1"/>
              <text x="459" y="186" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10.5" fill="#3b82f6">Simulation Engine</text>
              <text x="459" y="202" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="9.5" fill="#64748b">60 weighted personas · heuristic + stochastic scoring</text>
              <text x="459" y="215" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="9.5" fill="#64748b">Monte Carlo scenario ranges · checkpointed outputs</text>
              <!-- Arrow: Sim → LLM -->
              <line x1="459" y1="221" x2="459" y2="238" stroke="#475569" stroke-width="1.5" marker-end="url(#ecs-arr)"/>
              <!-- LLM Transport -->
              <rect x="239" y="241" width="440" height="74" rx="6" fill="#0f172a" stroke="#334155" stroke-width="1"/>
              <text x="459" y="260" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10.5" fill="#3b82f6">LLM Transport</text>
              <text x="459" y="276" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="9.5" fill="#64748b">retries · schema validation · cost accounting · provider abstraction</text>
              <rect x="255" y="284" width="52" height="18" rx="3" fill="#1e293b" stroke="#334155" stroke-width="1"/>
              <text x="281" y="297" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="8.5" fill="#94a3b8">Groq</text>
              <rect x="315" y="284" width="70" height="18" rx="3" fill="#1e293b" stroke="#334155" stroke-width="1"/>
              <text x="350" y="297" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="8.5" fill="#94a3b8">DeepSeek</text>
              <rect x="393" y="284" width="58" height="18" rx="3" fill="#1e293b" stroke="#334155" stroke-width="1"/>
              <text x="422" y="297" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="8.5" fill="#94a3b8">OpenAI</text>
              <rect x="459" y="284" width="54" height="18" rx="3" fill="#1e293b" stroke="#334155" stroke-width="1"/>
              <text x="486" y="297" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="8.5" fill="#94a3b8">Ollama</text>
              <rect x="521" y="284" width="142" height="18" rx="3" fill="#1e293b" stroke="#334155" stroke-width="1"/>
              <text x="592" y="297" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="8.5" fill="#64748b" font-style="italic">Heuristic Mode (offline)</text>
              <!-- Arrow: LLM → Artifacts -->
              <line x1="459" y1="315" x2="459" y2="332" stroke="#475569" stroke-width="1.5" marker-end="url(#ecs-arr)"/>
              <!-- Saved Artifacts -->
              <rect x="239" y="335" width="440" height="44" rx="6" fill="#0f172a" stroke="#334155" stroke-width="1"/>
              <text x="459" y="353" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10.5" fill="#3b82f6">Saved Artifacts</text>
              <rect x="304" y="361" width="40" height="14" rx="3" fill="#1e293b" stroke="#334155" stroke-width="1"/>
              <text x="324" y="372" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="8.5" fill="#94a3b8">JSON</text>
              <rect x="352" y="361" width="34" height="14" rx="3" fill="#1e293b" stroke="#334155" stroke-width="1"/>
              <text x="369" y="372" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="8.5" fill="#94a3b8">MD</text>
              <rect x="394" y="361" width="38" height="14" rx="3" fill="#1e293b" stroke="#334155" stroke-width="1"/>
              <text x="413" y="372" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="8.5" fill="#94a3b8">PDF</text>
              <rect x="440" y="361" width="44" height="14" rx="3" fill="#1e293b" stroke="#334155" stroke-width="1"/>
              <text x="462" y="372" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="8.5" fill="#94a3b8">PPTX</text>
              <text x="512" y="372" font-family="Inter, system-ui, sans-serif" font-size="9" fill="#475569">· run retrieval · reload</text>
            </svg>
          </div>

          <!-- Stack table -->
          <div class="mt-6 space-y-3">
            {[
              { layer: "Backend", tech: "Python standard library HTTP server + threads — APIs, async jobs, static serving, run retrieval" },
              { layer: "Frontend", tech: "React 19 + Vite 8 — run setup, polling, visual summaries, Monte Carlo exploration, persona browser" },
              { layer: "Simulation", tech: "Weighted persona modeling — heuristic scoring, stochastic adjustments, Monte Carlo ranges, checkpointed outputs" },
              { layer: "AI Layer", tech: "Groq, DeepSeek, OpenAI, Ollama — shared transport with retries, schema validation, usage/cost accounting" },
              { layer: "Persistence", tech: "Filesystem-first — JSON/MD run outputs, job state and logs, selector JSONs, local provider config" },
              { layer: "Reporting", tech: "Python → Markdown/HTML, headless PDF rendering, PptxGenJS for editable slide decks" },
            ].map((row) => (
              <div class="flex gap-4 p-3 rounded-lg bg-surface-800/30 border border-border/50">
                <span class="font-mono text-accent-blue text-xs w-24 flex-shrink-0 pt-0.5">{row.layer}</span>
                <span class="text-text-secondary text-sm">{row.tech}</span>
              </div>
            ))}
          </div>
        </section>

        <!-- Key Design Decisions -->
        <section>
          <h2 class="text-xl font-semibold text-text-primary mb-4 flex items-center gap-2">
            <span class="font-mono text-accent-blue text-sm">04</span>
            Key Design Decisions
          </h2>
          <div class="text-text-secondary leading-relaxed space-y-4">
            <p>
              <strong class="text-text-primary">Weighted personas over flat personas.</strong> Expanded from 15 generic archetypes to 60 weighted personas representing real organizational proportions. This made summary metrics represent a simulated org rather than disconnected characters — critical for executive trust.
            </p>
            <p>
              <strong class="text-text-primary">Kept heuristic mode alongside LLMs.</strong> Not every run needs hosted inference. Preserving a fast, low-cost simulation path made the tool practical for iterative message drafting, with LLM mode available when depth mattered more than speed.
            </p>
            <p>
              <strong class="text-text-primary">Saved outputs as first-class product objects.</strong> Run listing, retrieval, and reloading were built into the experience — not treated as throwaway files. This enabled executive reporting to operate off saved runs and made the tool credible as a decision-support system.
            </p>
            <p>
              <strong class="text-text-primary">Durable job lifecycle over request-response.</strong> The most consequential shift was moving from "one request, one response" to long-running jobs with persistent state, checkpoints, and explicit failure modes. Once Monte Carlo runs, LLM calls, and background tasks entered the picture, durability became a product requirement.
            </p>
          </div>
        </section>

        <!-- Challenges (selected highlights) -->
        <section>
          <h2 class="text-xl font-semibold text-text-primary mb-4 flex items-center gap-2">
            <span class="font-mono text-accent-blue text-sm">05</span>
            Challenges & Resolutions
          </h2>
          <div class="text-text-secondary leading-relaxed space-y-4 mb-6">
            <p>
              The project surfaced 10 significant engineering challenges. Here are the ones that
              best demonstrate systems thinking and product judgment:
            </p>
          </div>

          <div class="space-y-4">
            <div class="p-5 rounded-lg bg-surface-800/50 border border-border">
              <h3 class="font-medium text-text-primary text-sm mb-2">LLM runs exposed operational reality</h3>
              <p class="text-text-secondary text-sm leading-relaxed">
                At scale, the system moved from ideal prompt paths into provider-specific behavior:
                rate limits (Groq 429s), schema drift, inconsistent output fidelity. Resolution: backoff
                logic, transport retries, persona caps for validation, narrower schemas, and lighter
                default models. This demonstrates that AI systems succeed through operational discipline,
                not prompts alone.
              </p>
            </div>

            <div class="p-5 rounded-lg bg-surface-800/50 border border-border">
              <h3 class="font-medium text-text-primary text-sm mb-2">Dashboard lost state on refresh</h3>
              <p class="text-text-secondary text-sm leading-relaxed">
                The frontend initially treated the dashboard as a page, not a stateful task workspace.
                Resolution: persisted form state, active job IDs, and request snapshots with reconnect
                behavior after refresh. This shows product empathy — the implementation changed to fit
                the user's actual workflow, not the developer's happy path.
              </p>
            </div>

            <div class="p-5 rounded-lg bg-surface-800/50 border border-border">
              <h3 class="font-medium text-text-primary text-sm mb-2">Statistical output wasn't executive-friendly</h3>
              <p class="text-text-secondary text-sm leading-relaxed">
                Percentile language (p10/p50/p90) was mathematically correct but not intuitive for leaders.
                Resolution: reframed into "low case / typical case / high case," added explanatory copy,
                and turned thresholds into direct business questions. This separates useful tools from
                clever tools.
              </p>
            </div>

            <div class="p-5 rounded-lg bg-surface-800/50 border border-border">
              <h3 class="font-medium text-text-primary text-sm mb-2">Long-running jobs needed durable infrastructure</h3>
              <p class="text-text-secondary text-sm leading-relaxed">
                Runs could fail after stepping away, return with no results, or disappear without diagnostic
                evidence. Resolution: persisted job records, log files, checkpointed outputs after Monte Carlo
                passes, explicit interrupted states, and recovery from latest checkpoint. Classic systems
                leadership — design for observability and graceful degradation.
              </p>
            </div>
          </div>
        </section>

        <!-- Learnings -->
        <section>
          <h2 class="text-xl font-semibold text-text-primary mb-4 flex items-center gap-2">
            <span class="font-mono text-accent-blue text-sm">06</span>
            What I Learned
          </h2>

          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 my-6">
            <div class="p-5 rounded-lg bg-surface-800/50 border border-border">
              <h3 class="font-semibold text-text-primary mb-2 text-sm">Reliability matters as much as intelligence</h3>
              <p class="text-sm text-text-secondary">Good prompts and structured outputs are necessary but not sufficient. Retries, checkpoints, state persistence, and logs are what make AI features dependable.</p>
            </div>
            <div class="p-5 rounded-lg bg-surface-800/50 border border-border">
              <h3 class="font-semibold text-text-primary mb-2 text-sm">Analytics need translation</h3>
              <p class="text-sm text-text-secondary">Mathematically correct output isn't automatically decision-ready. Leaders need framing, thresholds, and scenario narratives — not raw statistical jargon.</p>
            </div>
            <div class="p-5 rounded-lg bg-surface-800/50 border border-border">
              <h3 class="font-semibold text-text-primary mb-2 text-sm">Adoption is a product design problem</h3>
              <p class="text-sm text-text-secondary">People use tools that match their workflow. Refresh recovery, saved runs, and report packaging mattered because they supported real behavior.</p>
            </div>
          </div>

          <div class="p-5 rounded-xl bg-surface-800/50 border-l-2 border-accent-blue">
            <p class="text-text-primary text-sm font-medium italic">
              "This project taught me how to move from model-centric thinking to system-centric thinking.
              The hard part was not generating reactions — it was building the surrounding product so those
              reactions could be trusted, revisited, explained, and acted on."
            </p>
          </div>
        </section>

        <!-- Why It Matters -->
        <section>
          <h2 class="text-xl font-semibold text-text-primary mb-4 flex items-center gap-2">
            <span class="font-mono text-accent-blue text-sm">07</span>
            Why This Matters
          </h2>
          <div class="text-text-secondary leading-relaxed space-y-4">
            <p>
              This project demonstrates the ability to take an ambiguous, cross-functional problem,
              build the first version quickly, recognize when the original architecture stops being
              good enough, and evolve the system into something more resilient, interpretable, and
              useful — all as a solo end-to-end build spanning backend, frontend, AI integration,
              simulation design, and executive reporting.
            </p>
            <p>
              It shows systems thinking, product design under real constraints, operational hardening
              of AI features, and the ability to translate analytics into decisions that leaders can
              act on.
            </p>
          </div>
        </section>

      </div>

      <!-- Navigation -->
      <div class="mt-16 pt-8 border-t border-border flex justify-between items-center">
        <a href="/projects/hermes-obsidian-gbrain" class="text-text-secondary hover:text-accent-blue transition-colors text-sm">
          &larr; Jarvis: Hermes AI OS
        </a>
        <a href="/projects/browser-workflow-qa-agent" class="text-accent-blue hover:text-accent-blue-hover transition-colors text-sm font-medium">
          Browser Workflow QA Agent &rarr;