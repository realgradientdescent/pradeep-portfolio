              <!-- Telegram -->
              <rect x="20" y="48" width="140" height="44" rx="6" fill="#0f172a" stroke="#3b82f6" stroke-width="1.5"/>
              <text x="90" y="68" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="11" fill="#3b82f6">Telegram</text>
              <text x="90" y="84" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="9.5" fill="#64748b">mobile · 24/7 access</text>
