              <text x="90" y="130" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="11" fill="#94a3b8">Cron Jobs</text>
              <text x="90" y="146" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="9.5" fill="#64748b">daily briefs · weekly syncs</text>
              <line x1="160" y1="132" x2="194" y2="100" stroke="#475569" stroke-width="1" stroke-dasharray="3,3" marker-end="url(#hob-arr)"/>

              <!-- Hermes Runtime (core) -->
              <rect x="196" y="48" width="310" height="100" rx="8" fill="#172554" stroke="#3b82f6" stroke-width="1.5"/>
              <text x="351" y="70" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="12" fill="#3b82f6" font-weight="600">Hermes Runtime — Jarvis</text>
              <text x="351" y="87" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="10" fill="#64748b">GPT-5.4 · DeepSeek · Claude (OpenRouter fallback)</text>
              <rect x="212" y="96" width="120" height="36" rx="4" fill="#0f172a" stroke="#334155" stroke-width="1"/>
              <text x="272" y="118" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="9.5" fill="#94a3b8">Tool execution</text>
              <rect x="344" y="96" width="148" height="36" rx="4" fill="#0f172a" stroke="#334155" stroke-width="1"/>
              <text x="418" y="118" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="9.5" fill="#94a3b8">Safety rails · approval gates</text>

              <!-- Google Workspace -->
              <rect x="524" y="48" width="152" height="44" rx="6" fill="#0f172a" stroke="#475569" stroke-width="1"/>
              <text x="600" y="68" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#94a3b8">Google Workspace</text>
              <text x="600" y="84" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="9.5" fill="#64748b">Gmail · Docs · Calendar</text>
              <line x1="506" y1="70" x2="524" y2="70" stroke="#475569" stroke-width="1" stroke-dasharray="3,3" marker-end="url(#hob-arr)"/>

              <!-- Down arrows from runtime -->
              <line x1="272" y1="148" x2="272" y2="186" stroke="#475569" stroke-width="1.5" marker-end="url(#hob-arr)"/>
              <line x1="351" y1="148" x2="351" y2="186" stroke="#475569" stroke-width="1.5" marker-end="url(#hob-arr)"/>
              <line x1="430" y1="148" x2="430" y2="186" stroke="#475569" stroke-width="1.5" marker-end="url(#hob-arr)"/>

              <!-- Memory layers -->
              <rect x="140" y="190" width="160" height="58" rx="6" fill="#0f172a" stroke="#334155" stroke-width="1"/>
              <text x="220" y="212" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#3b82f6">Memory</text>
