---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";

const experience = [
  {
    period: "2024 — Present",
    title: "Director of Software Engineering",
    org: "Evernorth Health Services",
    location: "Greater St. Louis",
    blurb:
      "Leads an engineering enablement organization covering stability and resilience engineering, performance testing, test engineering, test data platforms, and delivery planning. Operates a multi-million-dollar portfolio spanning teams in the US and India.",
  },
  {
    period: "2022 — 2024",
    title: "Senior Manager, Software Engineering",
    org: "Evernorth Health Services",
    location: "Greater St. Louis",
    blurb:
      "Led stability engineering, performance testing, and test enablement teams. Drove the modernization of performance testing tooling and the build-out of self-service platforms used across the engineering organization.",
  },
  {
    period: "2017 — 2022",
    title: "Senior Delivery Manager, Technology",
    org: "Evernorth Health Services",
    location: "Greater St. Louis",
    blurb:
      "Served as an IT security controls lead and delivery lead across infrastructure and reliability initiatives. Drove process and performance optimization for IT infrastructure operations and coached teams on agile delivery practices.",
  },
  {
    period: "2012 — 2017",
    title: "Senior Manager → Associate Director, Healthcare IT",
    org: "Cognizant",
    location: "Greater St. Louis",
    blurb:
      "Led large engineering delivery teams in healthcare IT consulting, spanning onshore and offshore. Drove process optimization, infrastructure and application strategy, and cross-functional delivery across multiple large engagements.",
  },
  {
    period: "2009 — 2012",
    title: "Service Delivery Manager, IT",
    org: "CGI",
    location: "Chattanooga, TN",
    blurb:
      "Managed a multi-site US–Canada–India healthcare engagement with a 70+ person cross-functional team. Led business continuity planning, delivery standardization, and post-release quality improvements.",
  },
  {
    period: "2006 — 2009",
    title: "IT Project Manager",
    org: "Mahindra Satyam",
    location: "Chattanooga, TN",
    blurb:
      "Built out an onsite–offshore delivery model in healthcare claims. Delivered QA automation improvements that materially increased test execution throughput.",
  },
  {
    period: "2003 — 2006",
    title: "IT Consultant and Project Lead",
    org: "Capgemini (Kanbay)",
    location: "Greater Chicago Area",
    blurb:
      "Led onshore–offshore delivery of medium-scale compliance IT programs under aggressive timelines. Identified as a company-wide trainer for core database platforms.",
  },
  {
    period: "2002 — 2003",
    title: "Module Lead",
    org: "UST Global",
    location: "India",
    blurb:
      "Started in engineering with direct client-facing requirements work, unit testing, and module ownership. Promoted to module leader within six months.",
  },
];

const strengths = [
  "Engineering leadership at portfolio scale",
  "AI enablement inside governed engineering workflows",
  "Platform thinking — turning capabilities into self-service products",
  "Reliability, resilience, and quality engineering",
  "Cost transparency and financial discipline",
  "Cross-functional influence across engineering, security, and finance",
  "Hands-on system building in parallel with leadership work",
  "Team building and continuous improvement culture",
];

const certifications = [
  { name: "Project Management Professional (PMP)", org: "Project Management Institute", year: "2008" },
  { name: "Agile Certified Practitioner (PMI-ACP)", org: "Project Management Institute", year: "2017" },
  { name: "MicroMasters in Cybersecurity", org: "Rochester Institute of Technology", year: "" },
  { name: "AI: Implications for Business Strategy", org: "MIT Sloan Executive Education", year: "2026" },
  { name: "Professional, Academy for Healthcare Management (PAHM)", org: "Center for Insurance Education", year: "" },
];
---

<BaseLayout title="Resume — Pradeep" description="Director of Software Engineering. Engineering leader with a hands-on AI building practice. Available for VP/Director of Engineering roles in AI enablement.">

  <section class="py-24">
    <div class="max-w-4xl mx-auto px-6">

      <p class="font-mono text-accent-blue text-sm mb-3">~/resume</p>
      <h1 class="text-4xl font-bold text-text-primary mb-3">Pradeep Kolakkampadath</h1>
      <p class="text-text-secondary text-lg mb-2">Director of Software Engineering · Evernorth Health Services</p>
      <p class="text-text-muted text-sm mb-16">Greater St. Louis, Missouri · 20+ years in enterprise software delivery and engineering leadership</p>

      <!-- Summary -->
      <div class="mb-16">
        <h2 class="text-xl font-semibold text-text-primary mb-4 flex items-center gap-2">
          <span class="font-mono text-accent-blue text-sm">01</span>
          Summary
        </h2>
        <div class="space-y-4 text-text-secondary leading-relaxed">
          <p>
            Engineering leader with 20+ years of progressive experience in enterprise software delivery, currently
            running an engineering enablement organization at Evernorth Health Services. Career arc moves from hands-on
            engineering through program and delivery management into platform-scale leadership of resiliency,
            reliability, and test enablement.
          </p>
          <p>
            Parallel to the leadership work, builds AI systems hands-on — multi-agent orchestration, memory and
            routing design, and reliability-first LLM products. The building informs the leadership perspective: AI
            enablement that works in practice, not just on slides.
          </p>
        </div>
      </div>

      <!-- Target Roles -->
      <div class="mb-16">
        <h2 class="text-xl font-semibold text-text-primary mb-4 flex items-center gap-2">
          <span class="font-mono text-accent-blue text-sm">02</span>
          Currently Targeting
        </h2>
        <ul class="space-y-2 text-text-secondary leading-relaxed list-none pl-0">
          <li class="flex gap-3"><span class="text-accent-blue mt-1">›</span><span>VP or Director of Engineering — AI Enablement</span></li>
          <li class="flex gap-3"><span class="text-accent-blue mt-1">›</span><span>Head of AI / ML Platform</span></li>
          <li class="flex gap-3"><span class="text-accent-blue mt-1">›</span><span>Engineering leadership at AI-forward companies where AI is woven into engineering practice, not bolted onto a product</span></li>
        </ul>
      </div>

      <!-- Selected Impact -->
      <div class="mb-16">
        <h2 class="text-xl font-semibold text-text-primary mb-4 flex items-center gap-2">
          <span class="font-mono text-accent-blue text-sm">03</span>
          Selected Impact (Director / Senior Manager Level)
        </h2>
        <div class="space-y-4 text-text-secondary leading-relaxed">
          <div class="p-4 rounded-lg bg-surface-800/40 border border-border">
            <p class="text-text-primary font-medium text-sm mb-1">Transformed performance testing into an enterprise platform</p>
            <p class="text-sm">Replaced legacy tooling with modern performance testing infrastructure, integrated dynamic environments, and launched a self-service front end. Release readiness and reliability improved, adoption scaled beyond a single team.</p>
          </div>
          <div class="p-4 rounded-lg bg-surface-800/40 border border-border">
            <p class="text-text-primary font-medium text-sm mb-1">Led AI and productivity enablement in the SDLC</p>
            <p class="text-sm">Partnered with architecture and the AI center of excellence on genAI-assisted test data tooling, developer assistance solutions, and productivity measurement frameworks. Moved AI from experimentation into governed, repeatable engineering workflows.</p>
          </div>
          <div class="p-4 rounded-lg bg-surface-800/40 border border-border">
            <p class="text-text-primary font-medium text-sm mb-1">Modernized mainframe delivery with CI/CD patterns</p>
            <p class="text-sm">Piloted bridge tooling that brought git-based CI/CD into mainframe environments, lowering developer onboarding friction on historically rigid platforms.</p>
          </div>
          <div class="p-4 rounded-lg bg-surface-800/40 border border-border">
            <p class="text-text-primary font-medium text-sm mb-1">Elevated enterprise security posture</p>
            <p class="text-sm">Drove enterprise adoption of automated dependency vulnerability management, built remediation visibility dashboards, and partnered with security on high-risk remediation outcomes.</p>
          </div>
          <div class="p-4 rounded-lg bg-surface-800/40 border border-border">
            <p class="text-text-primary font-medium text-sm mb-1">Delivered cost transparency and financial discipline</p>
            <p class="text-sm">Partnered with finance and portfolio leadership on total cost of ownership optimization and portfolio budget analysis. Improved funding alignment and leadership confidence in the enablement model.</p>
          </div>
          <div class="p-4 rounded-lg bg-surface-800/40 border border-border">
            <p class="text-text-primary font-medium text-sm mb-1">Built high-impact, recognized teams</p>
            <p class="text-sm">Strengthened hiring and internal capability, expanded automation and AI skills, and built a continuous improvement culture anchored in retrospectives and opportunity logs.</p>
          </div>
        </div>
      </div>

      <!-- Experience Timeline -->
      <div class="mb-16">
        <h2 class="text-xl font-semibold text-text-primary mb-4 flex items-center gap-2">
          <span class="font-mono text-accent-blue text-sm">04</span>
          Experience
        </h2>
        <div class="space-y-5">
          {experience.map((job) => (
            <div class="p-5 rounded-lg bg-surface-800/40 border border-border">
              <div class="flex flex-wrap items-baseline justify-between gap-2 mb-1">
                <h3 class="text-text-primary font-semibold text-base">{job.title}</h3>
                <span class="font-mono text-accent-blue text-xs">{job.period}</span>
              </div>
              <p class="text-text-secondary text-sm mb-2">{job.org} · <span class="text-text-muted">{job.location}</span></p>
              <p class="text-text-secondary text-sm leading-relaxed">{job.blurb}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Core Strengths -->
      <div class="mb-16">
        <h2 class="text-xl font-semibold text-text-primary mb-4 flex items-center gap-2">
          <span class="font-mono text-accent-blue text-sm">05</span>
          Core Strengths
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
          {strengths.map((s) => (
            <div class="flex items-start gap-2 text-text-secondary text-sm">
              <span class="text-accent-blue mt-1">›</span>
              <span>{s}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Certifications -->
      <div class="mb-16">
        <h2 class="text-xl font-semibold text-text-primary mb-4 flex items-center gap-2">
          <span class="font-mono text-accent-blue text-sm">06</span>
          Certifications
        </h2>
        <div class="space-y-2">
          {certifications.map((c) => (
            <div class="flex flex-wrap items-baseline gap-x-3 text-sm">
              <span class="text-text-primary font-medium">{c.name}</span>
              <span class="text-text-muted">{c.org}</span>
              {c.year && <span class="font-mono text-text-muted text-xs">{c.year}</span>}
            </div>
          ))}
        </div>
      </div>

      <!-- Education -->
      <div class="mb-16">
        <h2 class="text-xl font-semibold text-text-primary mb-4 flex items-center gap-2">
          <span class="font-mono text-accent-blue text-sm">07</span>
          Education
        </h2>
        <div class="text-sm">
          <p class="text-text-primary font-medium">B.Tech, Biomedical Engineering</p>
          <p class="text-text-secondary">Cochin University of Science and Technology · 1997 — 2001</p>
        </div>
      </div>

      <!-- Full resume on request -->
      <div class="mb-16">
        <h2 class="text-xl font-semibold text-text-primary mb-4 flex items-center gap-2">
          <span class="font-mono text-accent-blue text-sm">08</span>
          Full Resume
        </h2>
        <div class="p-6 rounded-xl bg-surface-800/40 border border-border">
          <p class="text-text-secondary text-sm leading-relaxed mb-5">
            The full resume and one-page summary are available on request. If you're a recruiter or hiring
            manager and would like a copy, drop me a line and I'll send it over.
          </p>
          <a
            href="mailto:pradeep@realgradientdescent.tech?subject=Resume%20request&body=Hi%20Pradeep%2C%0A%0AI%27d%20like%20a%20copy%20of%20your%20full%20resume.%0A%0AName%3A%0ACompany%3A%0ARole%3A%0A%0AThanks."
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-accent-blue hover:bg-accent-blue-hover text-white text-sm font-medium rounded-lg transition-colors"
          >
            Request resume by email
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
        </div>
      </div>

      <!-- CTA -->
      <div class="pt-8 border-t border-border flex flex-wrap gap-4">
        <a
          href="/ask"
          class="px-6 py-3 bg-accent-blue hover:bg-accent-blue-hover text-white font-medium rounded-lg transition-colors"
        >
          Ask my copilot
        </a>
        <a
          href="mailto:pradeep@realgradientdescent.tech"
          class="px-6 py-3 bg-surface-800 hover:bg-surface-700 text-text-primary font-medium rounded-lg border border-border transition-colors"
        >
          Get in touch
        </a>
      </div>

    </div>
  </section>

</BaseLayout>
