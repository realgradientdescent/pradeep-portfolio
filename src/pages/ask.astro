---
import BaseLayout from "../layouts/BaseLayout.astro";
import ChatWidget from "../components/ChatWidget.jsx";
import "../styles/global.css";

const url = new URL(Astro.request.url);
const initialPrompt = url.searchParams.get('q') || '';
---

<BaseLayout title="Ask Pradeep AI" description="An AI copilot grounded in Pradeep's professional context. Ask about his background, projects, and perspective.">
  <ChatWidget client:load initialPrompt={initialPrompt} />
</BaseLayout>
